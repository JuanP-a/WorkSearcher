# Meta Cloud API — WhatsApp Business (System User token, never expires)
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_ACCESS_TOKEN=your_permanent_system_user_token_here
META_RECIPIENT_PHONE=+521234567890  # con código de país
# META_API_VERSION=v21.0  # sólo cambiar cuando Meta deprece la versión actual

# ---------------------------------------------------------------------------
# Selección de scrapers — lista separada por comas de plataformas activas
# Valores válidos: jobspy, remoteok, remotive, wwr, cybersecjobs,
#                  computrabajo, bumeran, himalayas, hackernews, occ, getonboard
# "occ" NO está incluida en el default (opt-in): la estructura de URLs de
# occ.com.mx cambió; los jobs individuales están un nivel más abajo que
# el selector actual puede alcanzar. Ver docs/contexto/errores-conocidos.md.
# Para re-habilitar OCC: ENABLED_SCRAPERS=...occ
# ---------------------------------------------------------------------------
# ENABLED_SCRAPERS=jobspy,remoteok,remotive,wwr,cybersecjobs,computrabajo,bumeran,himalayas,hackernews,getonboard

# ---------------------------------------------------------------------------
# Filtro post-scraping — se aplica a TODOS los scrapers (sin límite de términos)
# ---------------------------------------------------------------------------
SEARCH_KEYWORDS=python,javascript,typescript,react,node.js,frontend,backend,fullstack,software engineer,developer,web developer,cybersecurity,security engineer,SOC analyst,pentester,infosec,ethical hacker,red team,blue team,cloud security,devops,automation,SRE

# ---------------------------------------------------------------------------
# jobspy (LinkedIn / Indeed / Glassdoor)
# ---------------------------------------------------------------------------
# Query enviada a jobspy — máximo 5 términos
JOBSPY_SEARCH_TERMS=python,cybersecurity,software engineer,devops,javascript

# Plataformas que jobspy consulta (válidos: linkedin, indeed, glassdoor)
# JOBSPY_SITES=linkedin,indeed,glassdoor

# Alcance geográfico (ej: "Mexico City", "Remote", "Buenos Aires")
# SEARCH_LOCATION=Remote

# ---------------------------------------------------------------------------
# Búsqueda local / presencial (México — Celaya y alrededores)
# ---------------------------------------------------------------------------
# Activa búsqueda de empleos presenciales en la ciudad configurada.
# Cuando True, los scrapers MX (Computrabajo, Bumeran, OCC) y jobspy
# también consultan posiciones on-site en vez de solo remotas.
# SEARCH_LOCAL_ENABLED=false
# MX_SEARCH_CITY=celaya
# MX_SEARCH_STATE=guanajuato

# Máximo de resultados por plataforma por ejecución
# JOBSPY_RESULTS_WANTED=50

# Solo devuelve empleos publicados en las últimas N horas
# JOBSPY_HOURS_OLD=24

# Cuando SEARCH_LOCAL_ENABLED=true, jobspy también consulta con
# location = MX_SEARCH_CITY + MX_SEARCH_STATE (ej: "Celaya, Guanajuato")
# e is_remote=False para capturar posiciones presenciales.

# ---------------------------------------------------------------------------
# Scrapers LatAm (Bumeran, Computrabajo)
# Cuando SEARCH_LOCAL_ENABLED=true, ambos scrapers también buscan posiciones
# presenciales en MX_SEARCH_CITY (sin filtrar por marcadores de remoto).
# ---------------------------------------------------------------------------
# Términos de búsqueda en español para Bumeran (los títulos son en español)
# BUMERAN_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# Términos de búsqueda en español para Computrabajo
# COMPUTRABAJO_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# ---------------------------------------------------------------------------
# OCC (occ.com.mx) — LatAm scraper, México
# URL de remoto: /tipo-home-office-remoto/
# URL local:   /en-{MX_SEARCH_STATE}/en-{MX_SEARCH_CITY}/ (cuando SEARCH_LOCAL_ENABLED=true)
#
# ⚠️  OCC está opt-in (no incluido en ENABLED_SCRAPERS por default).
# Para activarlo: agregar "occ" a ENABLED_SCRAPERS arriba.
# ---------------------------------------------------------------------------
# OCC_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# ---------------------------------------------------------------------------
# GetOnBoard (getonbrd.com) — LatAm, curado, salarios en USD
# Organiza por categoría, no por búsqueda libre. Sólo se incluyen jobs con el
# badge "Fully remote" (el sufijo -remote en la URL no es confiable — también
# aparece en jobs híbridos).
# ---------------------------------------------------------------------------
# GETONBOARD_CATEGORIES=programming,cybersecurity,sysadmin-devops-qa

# ---------------------------------------------------------------------------
# Himalayas
# ---------------------------------------------------------------------------
# Máximo de empleos obtenidos por ejecución desde la API de Himalayas
# HIMALAYAS_RESULTS_LIMIT=50

# ---------------------------------------------------------------------------
# Filtros
# ---------------------------------------------------------------------------
# Descarta empleos que pidan más años de experiencia que este número
MAX_YEARS_EXPERIENCE=3

# Descarta empleos con más de N días de antigüedad (0 = sin filtro)
MAX_JOB_AGE_DAYS=30

# Descarta empleos cuyo título/descripción contenga estas palabras (case-insensitive)
BLACKLIST_KEYWORDS=security clearance,active clearance,top secret,ts/sci,dod clearance,secret clearance,public trust,us citizens only,must be authorized to work in the us,us work authorization,must be a us citizen,green card required,sales executive,account executive,must relocate,relocation required,staffing agency,recruiting firm

# Idiomas permitidos en descripción (ISO 639-1). Vacío = sin filtro de idioma
FILTER_LANGUAGES=en,es

# Salario mínimo mensual en USD. Vacío = sin filtro de salario
MIN_SALARY_USD_MONTHLY=

# ---------------------------------------------------------------------------
# Notificaciones WhatsApp
# ---------------------------------------------------------------------------
# Máximo de empleos por mensaje de WhatsApp (el resto se guarda en DB para el siguiente ciclo)
# MAX_JOBS_PER_MESSAGE=10

# Timeout HTTP específico para la API de WhatsApp (segundos)
# WHATSAPP_HTTP_TIMEOUT_SECONDS=15

# ---------------------------------------------------------------------------
# Rendimiento
# ---------------------------------------------------------------------------
# Timeout HTTP en segundos para todos los scrapers basados en httpx
# HTTP_TIMEOUT_SECONDS=30

# Timeout máximo por scraper en el pipeline (evita que un browser Playwright colgado bloquee todo)
# SCRAPER_TIMEOUT_SECONDS=120

# Timeout de navegación Playwright (milisegundos)
# PLAYWRIGHT_PAGE_LOAD_TIMEOUT_MS=30000
# PLAYWRIGHT_SELECTOR_TIMEOUT_MS=10000

# Frecuencia de ejecución en horas — sólo referencia documental, el scheduling real es via cron
# SCRAPE_INTERVAL_HOURS=4

# ---------------------------------------------------------------------------
# Almacenamiento
# ---------------------------------------------------------------------------
# Ruta a la base de datos SQLite
# Dev local (relativa al repo):
# DB_PATH=worksearcher.db
# VPS (OBLIGATORIO: ruta absoluta fuera del repo para sobrevivir redeploys):
# DB_PATH=/var/lib/worksearcher/worksearcher.db

# ---------------------------------------------------------------------------
# Outreach en frío — extracción de correo de RH por coordenadas
# Pipeline SEPARADO del buscador de vacantes (comando `worksearcher outreach`,
# cron semanal, no cada 4h). El sistema SOLO EXTRAE — el envío de correo es
# manual, por el usuario, fuera de la app.
#
# OUTREACH_LAT/OUTREACH_LON deben configurarse para poder correr el comando
# `outreach`; sin ellos, el pipeline se salta con un error claro en el log.
# ---------------------------------------------------------------------------
# OUTREACH_LAT=20.1
# OUTREACH_LON=-100.8
# OUTREACH_RADIUS_KM=80

# Rutas de contacto a crawlear además de la home, buscando correo de RH
# OUTREACH_CONTACT_PATHS=/contacto,/trabaja-con-nosotros,/bolsa-de-trabajo,/careers,/rh

# Tope de empresas nuevas descubiertas por corrida (protege Overpass/crawl de radios grandes)
# OUTREACH_MAX_COMPANIES_PER_RUN=100

# Tope de empresas por mensaje de WhatsApp (el resto se reintenta la siguiente corrida semanal)
# OUTREACH_MAX_COMPANIES_PER_MESSAGE=30
