# Meta Cloud API — WhatsApp Business (System User token, never expires)
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_ACCESS_TOKEN=your_permanent_system_user_token_here
META_RECIPIENT_PHONE=+521234567890  # con código de país
# META_API_VERSION=v21.0  # sólo cambiar cuando Meta deprece la versión actual

# ---------------------------------------------------------------------------
# Selección de scrapers — lista separada por comas de plataformas activas
# Valores válidos: jobspy, remoteok, remotive, wwr, cybersecjobs,
#                  computrabajo, bumeran, himalayas, hackernews
# ---------------------------------------------------------------------------
# ENABLED_SCRAPERS=jobspy,remoteok,remotive,wwr,cybersecjobs,computrabajo,bumeran,himalayas,hackernews

# ---------------------------------------------------------------------------
# Filtro post-scraping — se aplica a TODOS los scrapers (sin límite de términos)
# ---------------------------------------------------------------------------
SEARCH_KEYWORDS=python,javascript,typescript,react,node.js,frontend,backend,fullstack,software engineer,developer,web developer,cybersecurity,security engineer,SOC analyst,pentester,infosec,ethical hacker,red team,blue team,cloud security,devops,automation,SRE

# ---------------------------------------------------------------------------
# jobspy (LinkedIn / Indeed / Glassdoor)
# ---------------------------------------------------------------------------
# Query enviada a jobspy — máximo 5 términos
JOBSPY_SEARCH_TERMS=python,cybersecurity,software engineer,devops,javascript

# Plataformas que jobspy consulta (válidos: linkedin, indeed, glassdoor)
# JOBSPY_SITES=linkedin,indeed,glassdoor

# Alcance geográfico (ej: "Mexico City", "Remote", "Buenos Aires")
# SEARCH_LOCATION=Remote

# Máximo de resultados por plataforma por ejecución
# JOBSPY_RESULTS_WANTED=50

# Solo devuelve empleos publicados en las últimas N horas
# JOBSPY_HOURS_OLD=24

# ---------------------------------------------------------------------------
# Scrapers LatAm (Bumeran, Computrabajo)
# ---------------------------------------------------------------------------
# Términos de búsqueda en español para Bumeran (los títulos son en español)
# BUMERAN_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# Términos de búsqueda en español para Computrabajo
# COMPUTRABAJO_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# ---------------------------------------------------------------------------
# OCC (occ.com.mx) — LatAm scraper, México
# Remote filter embebido en URL path (/tipo-home-office-remoto/) — no markers
# ---------------------------------------------------------------------------
# OCC_SEARCH_TERMS=desarrollador,programador,backend,ciberseguridad,seguridad informatica

# ---------------------------------------------------------------------------
# Himalayas
# ---------------------------------------------------------------------------
# Máximo de empleos obtenidos por ejecución desde la API de Himalayas
# HIMALAYAS_RESULTS_LIMIT=50

# ---------------------------------------------------------------------------
# Filtros
# ---------------------------------------------------------------------------
# Descarta empleos que pidan más años de experiencia que este número
MAX_YEARS_EXPERIENCE=3

# Descarta empleos con más de N días de antigüedad (0 = sin filtro)
MAX_JOB_AGE_DAYS=30

# Descarta empleos cuyo título/descripción contenga estas palabras (case-insensitive)
BLACKLIST_KEYWORDS=security clearance,active clearance,top secret,ts/sci,dod clearance,secret clearance,public trust,us citizens only,must be authorized to work in the us,us work authorization,must be a us citizen,green card required,sales executive,account executive,must relocate,relocation required,staffing agency,recruiting firm

# Idiomas permitidos en descripción (ISO 639-1). Vacío = sin filtro de idioma
FILTER_LANGUAGES=en,es

# Salario mínimo mensual en USD. Vacío = sin filtro de salario
MIN_SALARY_USD_MONTHLY=

# ---------------------------------------------------------------------------
# Notificaciones WhatsApp
# ---------------------------------------------------------------------------
# Máximo de empleos por mensaje de WhatsApp (el resto se guarda en DB para el siguiente ciclo)
# MAX_JOBS_PER_MESSAGE=10

# ---------------------------------------------------------------------------
# Rendimiento
# ---------------------------------------------------------------------------
# Timeout HTTP en segundos para todos los scrapers basados en httpx
# HTTP_TIMEOUT_SECONDS=30

# Timeout máximo por scraper en el pipeline (evita que un browser Playwright colgado bloquee todo)
# SCRAPER_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Almacenamiento
# ---------------------------------------------------------------------------
# Ruta a la base de datos SQLite — en VPS usar ruta absoluta fuera del repo
# DB_PATH=worksearcher.db
